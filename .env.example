# cp .env.example .env 후 값을 채워 사용하세요

# YouTrack instance URL (no trailing slash)
YOUTRACK_BASE_URL=https://your-company.youtrack.cloud

# Permanent token: Profile → Account security → New token
YOUTRACK_TOKEN=perm:xxxxxxxx

# 기술 자료 문서 ID 접두사 (예: XAC-13 의 XAC)
YOUTRACK_ARTICLE_PREFIX=XAC

# 기술 자료 md 동기화 로컬 경로
YOUTRACK_DOCS_DIR=./docs

# push 시 기본 프로젝트 (보통 ARTICLE_PREFIX 와 동일)
YOUTRACK_PROJECT=XAC
# YOUTRACK_PARENT_ARTICLE=XAC-1
